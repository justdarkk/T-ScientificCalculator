<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="☰"
                android:textColor="@color/primaryText"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="T-Scientific Calculator"
                android:textColor="@color/primaryText"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnHistory"
                android:layout_width="115dp"
                android:layout_height="50dp"
                android:background="@drawable/button_number"
                android:text="History"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <!-- Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/display_background"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text=""
                android:textColor="@color/secondaryText"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/txtDisplay"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="end|center_vertical"
                android:text="0"
                android:textColor="@color/primaryText"
                android:textSize="42sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Scientific Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnSin"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="sin" />

            <Button
                android:id="@+id/btnCos"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="cos" />

            <Button
                android:id="@+id/btnTan"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="tan" />

            <Button
                android:id="@+id/btnLog"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="log" />

            <Button
                android:id="@+id/btnLn"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="ln" />
        </LinearLayout>

        <!-- Scientific Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnRoot"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="√" />

            <Button
                android:id="@+id/btnSquare"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="x²" />

            <Button
                android:id="@+id/btnPower"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="xʸ" />

            <Button
                android:id="@+id/btnPi"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="π" />

            <Button
                android:id="@+id/btnE"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="e" />
        </LinearLayout>

        <!-- Scientific Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnFactorial"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="n!" />

            <Button
                android:id="@+id/btnNpr"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="nPr" />

            <Button
                android:id="@+id/btnNcr"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="nCr" />

            <Button
                android:id="@+id/btnOpenBracket"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text="(" />

            <Button
                android:id="@+id/btnCloseBracket"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:background="@drawable/button_number"
                android:text=")" />
        </LinearLayout>

        <!-- Number Rows -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:layout_marginTop="12dp">

            <Button android:id="@+id/btn7" android:text="7" android:background="@drawable/button_number"/>
            <Button android:id="@+id/btn8" android:text="8" android:background="@drawable/button_number"/>
            <Button android:id="@+id/btn9" android:text="9" android:background="@drawable/button_number"/>
            <Button android:id="@+id/btnDivide" android:text="÷" android:background="@drawable/button_operator"/>

            <Button android:id="@+id/btn4" android:text="4" android:background="@drawable/button_number"/>
            <Button android:id="@+id/btn5" android:text="5" android:background="@drawable/button_number"/>
            <Button android:id="@+id/btn6" android:text="6" android:background="@drawable/button_number"/>
            <Button android:id="@+id/btnMultiply" android:text="×" android:background="@drawable/button_operator"/>

            <Button android:id="@+id/btn1" android:text="1" android:background="@drawable/button_number"/>
            <Button android:id="@+id/btn2" android:text="2" android:background="@drawable/button_number"/>
            <Button android:id="@+id/btn3" android:text="3" android:background="@drawable/button_number"/>
            <Button android:id="@+id/btnMinus" android:text="-" android:background="@drawable/button_operator"/>

            <Button android:id="@+id/btn0" android:text="0" android:background="@drawable/button_number"/>
            <Button android:id="@+id/btnDot" android:text="." android:background="@drawable/button_number"/>
            <Button android:id="@+id/btnClear" android:text="C" android:background="@drawable/button_operator"/>
            <Button android:id="@+id/btnPlus" android:text="+" android:background="@drawable/button_operator"/>

        </GridLayout>

        <!-- Equals Button -->
        <Button
            android:id="@+id/btnEquals"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/button_equals"
            android:text="="
            android:textColor="@color/primaryText"
            android:textSize="30sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>